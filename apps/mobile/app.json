{
  "expo": {
    "name": "ViTAH",
    "slug": "vitah-app",
    "scheme": "vitah",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "vitah.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e1e1e"
      },
      "package": "app.vitah"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
