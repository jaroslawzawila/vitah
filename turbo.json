{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["POSTGRES_URL"]
    },
    "db:push": {
      "cache": false,
      "env": ["POSTGRES_URL"]
    },
    "db:seed": {
      "cache": false,
      "env": ["POSTGRES_URL", "SEED_TENANT_NAME", "SEED_ADMIN_EMAIL", "SEED_ADMIN_PASSWORD"]
    },
    "db:generate": {
      "cache": false,
      "env": ["POSTGRES_URL"]
    },
    "db:migrate": {
      "cache": false,
      "env": ["POSTGRES_URL"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true,
      "env": ["POSTGRES_URL"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
